# Load necessary libraries
library(readxl)
library(psych)
library(boot)
library(ggplot2)
library(ggridges)
library(cowplot)

# Step 1: Create a combined data frame for bootstrapped correlations and summary statistics
# Create a combined dataframe with all bootstrapped correlations and a column for the gene groups
bootdiff.dat <- data.frame(
  val = c(bootstrapped_correlations_oxphos, bootstrapped_correlations_gly, bootstrapped_correlations_cc,
          bootstrapped_correlations_cy, bootstrapped_correlations_cprp),
  comp = rep(c("N-mt OXPHOS", "Glycolysis", "Cell Cycle", "Cyto-ribo", "Plastid"), 
             times = c(length(bootstrapped_correlations_oxphos), length(bootstrapped_correlations_gly), 
                       length(bootstrapped_correlations_cc), length(bootstrapped_correlations_cy), 
                       length(bootstrapped_correlations_cprp)))
)

# Calculate summary statistics for each complex
sum_stat <- data.frame(
  comp = c("N-mt OXPHOS", "Glycolysis", "Cell Cycle", "Cyto-ribo", "Plastid"),
  val = c(mean_corr_oxphos, mean_corr_gly, mean_corr_cc, mean_corr_cy, mean_corr_cprp),
  lwr = c(ci_low_oxphos, ci_low_gly, ci_low_cc, ci_low_cy, ci_low_cprp),
  upr = c(ci_high_oxphos, ci_high_gly, ci_high_cc, ci_high_cy, ci_high_cprp)
)

# Adjust the levels of the 'comp' factor to reorder the y-axis from N-mt OXPHOS to Plastid (from top to bottom)
bootdiff.dat$comp <- factor(bootdiff.dat$comp, levels = rev(c("N-mt OXPHOS", "Glycolysis", "Cell Cycle", "Cyto-ribo", "Plastid")))
sum_stat$comp <- factor(sum_stat$comp, levels = rev(c("N-mt OXPHOS", "Glycolysis", "Cell Cycle", "Cyto-ribo", "Plastid")))

# Create the combined correlation distribution plot with adjustments for visibility
Gene_Groups_ERC <- ggplot(bootdiff.dat, aes(x = val, y = comp)) +
  geom_vline(xintercept = 0, linetype = "dashed") +
  geom_density_ridges(aes(fill = comp), alpha = 0.6, scale = 1) +  # Increased scale and alpha for better visibility
  geom_errorbarh(inherit.aes = FALSE, data = sum_stat,
                 aes(xmin = lwr, xmax = upr, y = comp), lwd = 1.5,
                 height = 0.2, show.legend = FALSE) +
  geom_point(inherit.aes = FALSE, data = sum_stat,
             aes(x = val, y = comp), pch = 21, 
             color = "black", size = 5, show.legend = FALSE) +
  theme_cowplot() +
  scale_fill_manual(values = c("N-mt OXPHOS" = "#666666", "Glycolysis" = "#CC6600",  
                               "Cell Cycle" = "#9999FF", "Cyto-ribo" = "#FF6666", 
                               "Plastid" = "#66CC99"), guide = "none") +
  labs(x = expression(paste("Evolutionary rate correlation strength  ", (italic(r[s])))),
       y = "ERC between mt and") +
  theme(legend.position = "none",   # Ensure the legend is completely removed
        axis.text = element_text(size = 18),  # Reduce axis text size
        axis.title = element_text(size = 20),  # Reduce axis title size
        legend.text = element_text(size = 20),
        legend.title = element_text(size = 20),
        legend.key.size = unit(1, 'cm')) +
  scale_x_continuous(limits = c(-0.6, 1), breaks = seq(-0.4, 1, by = 0.2))

# Display the combined plot
print(Gene_Groups_ERC)

