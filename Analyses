###### Load libraries
library(readxl)
library(psych)
library(boot)
library(ggplot2)

# Load your data from the Excel file
data1 <- read_excel("mt_N_mt_OXPHOS_complexes_branch_lengths_FINAL.xlsx")

### Complex I using "mt_N_mt_OXPHOS_complexes_branch_lengths_FINAL.xlsx"
# Step 1: Filter the data for Complex I (CI)
ci_data <- subset(data1, Complex == "CI")

# Separate the data into mt and N-mt gene groups
mt_data_ci <- subset(ci_data, `Type of gene group (mt or N-mt)` == "mt")
n_mt_data_ci <- subset(ci_data, `Type of gene group (mt or N-mt)` == "N-mt")

# Ensure species order is aligned between mt and N-mt data
# (Assumes species names are the same between mt and N-mt)
mt_data_ci <- mt_data_ci[order(mt_data_ci$Species), ]
n_mt_data_ci <- n_mt_data_ci[order(n_mt_data_ci$Species), ]

# Step 2: Calculate Spearman correlation using corr.test
corr_result_ci <- corr.test(mt_data_ci$`Normalized Root to Tip Branch Length`,
                            n_mt_data_ci$`Normalized Root to Tip Branch Length`,
                            method = "spearman")

# Step 3: Bootstrap the Spearman correlation
bootstrap_function_ci <- function(data, indices) {
  d <- data[indices, ]
  cor(d$mt_branch, d$n_mt_branch, method = "spearman")
}

# Create a combined dataframe for bootstrapping
combined_data_ci <- data.frame(
  mt_branch = mt_data_ci$`Normalized Root to Tip Branch Length`,
  n_mt_branch = n_mt_data_ci$`Normalized Root to Tip Branch Length`
)

bootstrap_results_ci <- boot(data = combined_data_ci, statistic = bootstrap_function_ci, R = 10000)

# Step 4: Calculate the 95% confidence intervals
ci_ci <- boot.ci(bootstrap_results_ci, type = "bca")

# Step 5: Interpret the results
print(ci_ci)

# Step 6: Extract the correlation value from the original corr.test result
# Calculate Spearman correlation directly
rs_value_ci <- cor(mt_data_ci$`Normalized Root to Tip Branch Length`,
                   n_mt_data_ci$`Normalized Root to Tip Branch Length`,
                   method = "spearman")

print(rs_value_ci)

# Step 7 correlation test and p-value 
# Calculate Spearman correlation and p-value
correlation_test1 <- cor.test(mt_data_ci$`Normalized Root to Tip Branch Length`,
                              n_mt_data_ci$`Normalized Root to Tip Branch Length`,
                              method = "spearman")

# Extract the p-value and the correlation coefficient (r_s)
rs_value_ci <- correlation_test1$estimate
p_value_ci <- correlation_test1$p.value

# Print the results
print(paste("Spearman correlation (r_s):", rs_value_ci))
print(paste("p-value:", p_value_ci))

# Check if p-value is less than 0.001 and format accordingly
p_value_label <- ifelse(p_value_ci < 0.001, "<0.001", round(p_value_ci, 4))

# Create a combined dataframe for plotting
plot_data_ci <- data.frame(
  Species = mt_data_ci$Species,
  mt_branch = mt_data_ci$`Normalized Root to Tip Branch Length`,
  n_mt_branch = n_mt_data_ci$`Normalized Root to Tip Branch Length`,
  Group = mt_data_ci$`Other Legumes (OL) or 50-kb (50kb)`
)

# Create the scatter plot with regression lines for 50-kb, Other Legumes, and All taxa
scatter_plot_CI <- ggplot(plot_data_ci, aes(x = n_mt_branch, y = mt_branch, color = Group)) +
  geom_point(size = 3, alpha = 0.7) +
  
  # Regression line for 50-kb legumes in red
  geom_smooth(data = subset(plot_data_ci, Group == "50kb"), 
              aes(x = n_mt_branch, y = mt_branch), 
              method = "lm", se = FALSE, color = "red") +
  
  # Regression line for Other Legumes in blue
  geom_smooth(data = subset(plot_data_ci, Group == "OL"), 
              aes(x = n_mt_branch, y = mt_branch), 
              method = "lm", se = FALSE, color = "blue") +
  
  # Regression line for all taxa in black
  geom_smooth(method = "lm", se = FALSE, color = "black", linetype = "dashed") +
  
  labs(title = "Complex I",
       x = "N-mt Branch Length",
       y = "mt Branch Length") +
  scale_color_manual(values = c("50kb" = "red", "OL" = "blue"),
                     labels = c("50kb" = "50-kb Legumes", "OL" = "Other Legumes")) +
  theme_minimal() +
  theme(
    plot.title = element_text(hjust = 0.5, face = "bold"),
    legend.position = "right",
    panel.grid = element_blank(),            # Remove grid lines
    panel.border = element_rect(color = "black", fill = NA)  # Add edge lines
  ) +
  annotate("text", x = min(plot_data_ci$n_mt_branch), y = max(plot_data_ci$mt_branch),
           label = bquote(r[s] == .(round(rs_value_ci, 2)) ~ "\n" ~ "p =" ~ .(p_value_label)),
           hjust = 0, vjust = 1, size = 5, color = "black")

# Display the scatter plot for Complex I
print(scatter_plot_CI)


# Step 8: Distribution curve of 95% Confidence Interval for Complex I
# Extract the bootstrapped correlations from the bootstrap results
bootstrapped_correlations_ci <- bootstrap_results_ci$t

# Calculate the 95% confidence interval
ci_low_ci <- ci_ci$bca[4]  # Lower bound of the 95% CI
ci_high_ci <- ci_ci$bca[5] # Upper bound of the 95% CI

# Calculate the mean of the bootstrapped correlations
mean_corr_ci <- mean(bootstrapped_correlations_ci)

# Create a dataframe for plotting
boot_data_ci <- data.frame(correlations = bootstrapped_correlations_ci)

# Plot the distribution with the mean point and error bars for the 95% CI
correlation_plot_CI <- ggplot(boot_data_ci, aes(x = correlations)) +
  geom_density(fill = "blue", alpha = 0.5) +
  geom_point(aes(x = mean_corr_ci, y = 0), size = 4, color = "black") +  # Add mean point
